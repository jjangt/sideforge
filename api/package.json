{
  "name": "sideforge-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env development",
    "db:init": "wrangler d1 execute sideforge-db --file=./schema.sql",
    "db:init:local": "wrangler d1 execute sideforge-db --file=./schema.sql --local"
  },
  "devDependencies": {
    "wrangler": "^4.0.0",
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
